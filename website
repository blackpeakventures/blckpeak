<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Black Peak Ventures</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,200;0,300;1,200;1,300&family=Inter:wght@200;300&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html,body{height:100%;background:#000;color:#fff;font-family:'Inter',sans-serif;font-weight:200;overflow-x:hidden;cursor:none;}
#cursor{position:fixed;width:8px;height:8px;background:#fff;border-radius:50%;pointer-events:none;z-index:9999;transform:translate(-50%,-50%);transition:width 0.3s,height 0.3s;mix-blend-mode:difference;}
#cursor-ring{position:fixed;width:36px;height:36px;border:0.5px solid rgba(255,255,255,0.5);border-radius:50%;pointer-events:none;z-index:9998;transform:translate(-50%,-50%);transition:opacity 0.3s;}
#noise{position:fixed;inset:0;pointer-events:none;z-index:1;opacity:0.03;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");background-size:200px;}
#scanlines{position:fixed;inset:0;pointer-events:none;z-index:2;background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(255,255,255,0.012) 2px,rgba(255,255,255,0.012) 4px);}
#canvas{position:fixed;inset:0;pointer-events:none;z-index:0;}
#page{position:relative;z-index:10;display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100vh;padding:3rem 2rem;opacity:0;}

/* Brand Typography Header */
.logo-wrap{display:flex;justify-content:center;align-items:center;width:100%;
margin-bottom:1rem;}

.main-logo{width:min(90vw,700px);height:auto;display:block;filter:brightness(0) invert(1);}

.divider{width:100%;max-width:400px;height:0.5px;background:linear-gradient(90deg,transparent,rgba(255,255,255,0.3),transparent);margin:0 auto 2rem;position:relative;overflow:visible;}
.divider-pulse{position:absolute;top:-1px;left:-100%;width:60px;height:3px;background:linear-gradient(90deg,transparent,#fff,transparent);animation:scan 4s ease-in-out infinite;filter:blur(1px);}
@keyframes scan{0%{left:-20%;}100%{left:120%;}}

/* Download Button styling */
.links-section{width:min(90vw,440px);margin:0 auto 1.8rem auto;display:flex;flex-direction:column;gap:12px;}
.download-button{display:flex;align-items:center;justify-content:space-between;padding:1.4rem 2rem;text-decoration:none;color:#fff;background:transparent;border:1px solid rgba(255,255,255,0.15);border-radius:4px;transition:background 0.4s cubic-bezier(0.16,1,0.3,1),color 0.4s,border-color 0.4s;position:relative;overflow:hidden;}
.download-button::before{content:'';position:absolute;inset:0;background:#fff;transform:translateX(-101%);transition:transform 0.5s cubic-bezier(0.16,1,0.3,1);z-index:0;}
.download-button:hover::before{transform:translateX(0);}
.download-button:hover{color:#000;border-color:#fff;}
.download-button *{position:relative;z-index:1;}
.btn-meta{display:flex;flex-direction:column;text-align:left;}
.btn-action{font-size:0.55rem;letter-spacing:0.2em;text-transform:uppercase;opacity:0.5;margin-bottom:2px;}
.download-button:hover .btn-action{opacity:0.7;}
.btn-title{font-family:'Cormorant Garamond',serif;font-weight:300;font-size:1.45rem;letter-spacing:0.1em;text-transform:uppercase;}
.download-icon{width:20px;height:20px;fill:none;stroke:currentColor;stroke-width:1.5;opacity:0.6;transition:transform 0.4s cubic-bezier(0.16,1,0.3,1);}
.download-button:hover .download-icon{transform:translateY(2px);}

.section-label{font-size:0.55rem;letter-spacing:0.35em;text-transform:uppercase;color:#fff;opacity:0.2;margin-bottom:1rem;text-align:center;}

/* Socials Grid */
.socials-section{width:min(90vw,440px);margin:0 auto;}
.social-row{display:flex;gap:1px;background:rgba(255,255,255,0.08);}
.social-link{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10px;padding:1.4rem 0.5rem;text-decoration:none;color:#fff;background:#000;transition:background 0.4s cubic-bezier(0.16,1,0.3,1),color 0.4s;font-size:0.55rem;letter-spacing:0.2em;text-transform:uppercase;position:relative;overflow:hidden;text-align:center;}
.social-link::before{content:'';position:absolute;inset:0;background:#fff;transform:translateY(101%);transition:transform 0.5s cubic-bezier(0.16,1,0.3,1);z-index:0;}
.social-link:hover::before{transform:translateY(0);}
.social-link:hover{color:#000;}
.social-link *{position:relative;z-index:1;}
.social-icon{width:18px;height:18px;fill:currentColor;}

.footer-text{margin-top:3rem;font-size:0.52rem;letter-spacing:0.3em;text-transform:uppercase;color:#fff;opacity:0.1;}

#intro{position:fixed;inset:0;background:#000;z-index:100;display:flex;align-items:center;justify-content:center;animation:introOut 1.2s cubic-bezier(0.76,0,0.24,1) 0.4s forwards;}
#intro-logo-text{font-family:'Cormorant Garamond',serif;font-weight:200;font-size:2.5rem;letter-spacing:0.25em;text-transform:uppercase;color:#fff;animation:introLogoOut 0.4s ease 0.3s forwards;}
@keyframes introOut{0%{clip-path:inset(0 0 0 0);}100%{clip-path:inset(0 0 100% 0);}}
@keyframes introLogoOut{to{opacity:0;}}

.reveal{opacity:0;transform:translateY(20px);transition:opacity 0.9s cubic-bezier(0.16,1,0.3,1),transform 0.9s cubic-bezier(0.16,1,0.3,1);}
.reveal.in{opacity:1;transform:translateY(0);}

@media (max-width:768px){
  .logo-text-top{font-size:2.2rem;}
  #page{padding:2rem 1rem;}
  .download-button{padding:1.1rem 1.5rem;}
  .btn-title{font-size:1.2rem;}
  .social-link{font-size:0.5rem;letter-spacing:0.15em;}
}
</style>
</head>
<body>
<div id="noise"></div>
<div id="scanlines"></div>
<canvas id="canvas"></canvas>

<div id="intro">
  <div id="intro-logo-text">Black Peak</div>
</div>

<div id="page">
  <div class="logo-wrap reveal">
  <img src="./logo.png" alt="Black Peak Ventures" class="main-logo">
</div>

  <div class="divider reveal">
    <div class="divider-pulse"></div>
  </div>

  <div class="links-section reveal">
    <a href="https://blackpeakventures.com" class="download-button" target="_blank">
      <div class="btn-meta">
        <span class="btn-action">Launch Platform</span>
        <span class="btn-title">Website</span>
      </div>
      <svg class="download-icon" viewBox="0 0 24 24"><path d="M12 4v12m0 0l-4-4m4 4l4-4M4 20h16" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </a>

    <a href="mailto:info@blackpeakventures.com" class="download-button">
      <div class="btn-meta">
        <span class="btn-action">Direct Secure Line</span>
        <span class="btn-title">Contact</span>
      </div>
      <svg class="download-icon" viewBox="0 0 24 24"><path d="M12 4v12m0 0l-4-4m4 4l4-4M4 20h16" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </a>
  </div>

  <div class="section-label reveal">Connect</div>

  <div class="socials-section reveal">
    <div class="social-row">
      <a href="https://www.tiktok.com/@blackpeakventures" class="social-link" target="_blank">
        <svg class="social-icon" viewBox="0 0 24 24"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.02 1.61 4.17 1.12 1.24 2.69 1.99 4.31 2.21v3.9c-1.28-.01-2.54-.31-3.69-.9-1.02-.55-1.89-1.37-2.48-2.38v7.07c.05 1.7-.42 3.39-1.37 4.79-.97 1.41-2.4 2.44-4.04 2.89-1.7.47-3.52.33-5.13-.41-1.61-.73-2.92-2.04-3.66-3.64-.75-1.6-.9-3.41-.44-5.1.45-1.65 1.48-3.07 2.89-4.04 1.35-.94 3.01-1.42 4.67-1.37.58.01 1.15.08 1.71.21v3.97c-.52-.18-1.08-.26-1.63-.23-1.07.03-2.1.51-2.81 1.32-.72.82-.99 1.92-.76 2.99.23 1.07.95 1.95 1.92 2.4.98.46 2.11.41 3.04-.15.9-.55 1.45-1.52 1.47-2.57V.02z"/></svg>
        TikTok
      </a>
      <a href="https://www.instagram.com/blackpeakventures" class="social-link" target="_blank">
        <svg class="social-icon" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.051.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
        Instagram
      </a>
      <a href="https://www.youtube.com/@blackpeakventures" class="social-link" target="_blank">
        <svg class="social-icon" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        YouTube
      </a>
    </div>
  </div>

  <div class="footer-text reveal">© 2026 Black Peak Ventures. All Rights Reserved.</div>
</div>

<script>
document.addEventListener('DOMContentLoaded',()=>{
  setTimeout(()=>{
    document.getElementById('page').style.opacity='1';
    const revs=document.querySelectorAll('.reveal');
    revs.forEach((r,i)=>{
      setTimeout(()=>{ r.classList.add('in'); },i*150);
    });
  },1000);
});

const cur=document.getElementById('cursor'),ring=document.getElementById('cursor-ring');
document.addEventListener('mousemove',(e)=>{
  cur.style.left=e.clientX+'px';cur.style.top=e.clientY+'px';
  ring.style.left=e.clientX+'px';ring.style.top=e.clientY+'px';
});
document.querySelectorAll('a').forEach(a=>{
  a.addEventListener('mouseenter',()=>{cur.style.width='40px';cur.style.height='40px';ring.style.opacity='0';});
  a.addEventListener('mouseleave',()=>{cur.style.width='8px';cur.style.height='8px';ring.style.opacity='1';});
});

const canvas=document.getElementById('canvas'),ctx=canvas.getContext('2d');
let W,H;
function resize(){W=canvas.width=window.innerWidth;H=canvas.height=window.innerHeight;}
resize();window.addEventListener('resize',resize);
const particles=Array.from({length:60},()=>({x:Math.random()*window.innerWidth,y:Math.random()*window.innerHeight,vx:(Math.random()-0.5)*0.3,vy:-Math.random()*0.4-0.1,opacity:Math.random()*0.4+0.05,size:Math.random()*1.5+0.3}));
let t=0;
function draw(){
  ctx.clearRect(0,0,W,H);t+=0.005;
  const cx=W/2,cy=H*0.42;
  for(let i=1;i<=8;i++){
    const scale=i*0.13,alpha=0.03+0.015*Math.sin(t+i*0.5);
    ctx.beginPath();ctx.moveTo(cx-W*0.5*scale,cy+H*0.35*scale);ctx.lineTo(cx,cy-H*0.45*scale);ctx.lineTo(cx+W*0.5*scale,cy+H*0.35*scale);
    ctx.strokeStyle=`rgba(255,255,255,${alpha})`;ctx.lineWidth=0.5;ctx.closePath();ctx.stroke();
  }
  particles.forEach(p=>{
    p.x+=p.vx;p.y+=p.vy;
    if(p.x<0||p.x>W)p.vx*=-1;
    if(p.y<0){p.y=H;p.x=Math.random()*W;}
    ctx.beginPath();ctx.arc(p.x,p.y,p.size,0,Math.PI*2);
    ctx.fillStyle=`rgba(255,255,255,${p.opacity})`;ctx.fill();
  });
  requestAnimationFrame(draw);
}
draw();
</script>
</body>
</html>
